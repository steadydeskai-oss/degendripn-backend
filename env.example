# ============================================================
# DegenDrip Backend — Environment Variables
# Copy this file to .env and fill in your real keys
# ============================================================

# Server
PORT=3001
FRONTEND_URL=http://localhost:5500

# Stripe
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Printful
# Get this from https://www.printful.com/dashboard/store/api-key
PRINTFUL_API_KEY=...

# ============================================================
# PRINTFUL VARIANT IDs
# After connecting Printful:
# 1. Go to your Printful store
# 2. Add each product (t-shirt, hoodie, etc.) as a "sync product"
# 3. Copy the sync variant IDs for each size/color combo
# 4. Fill them in below
# ============================================================

# Classic Tee (Bella+Canvas 3001 or Gildan 64000, White)
PRINTFUL_TSHIRT_S=
PRINTFUL_TSHIRT_M=
PRINTFUL_TSHIRT_L=
PRINTFUL_TSHIRT_XL=
PRINTFUL_TSHIRT_2XL=

# Premium Hoodie (Gildan 18500, White)
PRINTFUL_HOODIE_S=
PRINTFUL_HOODIE_M=
PRINTFUL_HOODIE_L=
PRINTFUL_HOODIE_XL=
PRINTFUL_HOODIE_2XL=

# Snapback Cap (one size)
PRINTFUL_SNAPBACK=

# Sticker Pack x5
PRINTFUL_STICKERS=

# Ceramic Mug 15oz
PRINTFUL_MUG=

# Phone Case (one variant per model)
PRINTFUL_PHONECASE_IP15=
PRINTFUL_PHONECASE_IP15PRO=
PRINTFUL_PHONECASE_IP14=
PRINTFUL_PHONECASE_S24=
PRINTFUL_PHONECASE_S23=

# Canvas Tote Bag
PRINTFUL_TOTE=

# Button Pins x3
PRINTFUL_PINS=
